# ============================================================
# Lore — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ------------------------------------------------------------
# Google AI / Gemini API
# Get from: https://aistudio.google.com/app/apikey
# Used for: Gemini Live API (ADK agent) + image generation
# ------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# ------------------------------------------------------------
# Google Cloud Project
# Your GCP project ID (not name) — e.g. "lore-ai-hackathon"
# Only needed for Cloud Run deployment
# ------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# ------------------------------------------------------------
# Server config
# ------------------------------------------------------------
PORT=8080

# ------------------------------------------------------------
# Client config (Vite env vars — must be prefixed VITE_)
# Set to your Cloud Run URL after deployment
# ------------------------------------------------------------
VITE_SERVER_URL=ws://localhost:8080
